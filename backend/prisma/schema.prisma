generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model analyzer_findings {
  id                String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  job_id            String                    @db.Uuid
  fingerprint       String                    @unique
  analyzer          String                    @db.VarChar(100)
  analyzer_version  String?                   @db.VarChar(20)
  finding_type      String                    @db.VarChar(100)
  category          String?                   @db.VarChar(100)
  severity          analyzer_finding_severity
  confidence        Float?
  title             String?
  summary           String?
  recommendation    String?
  log_references    Json?
  affected_entities Json?
  evidence          Json?
  metadata          Json?
  status            analyzer_finding_status   @default(ACTIVE)
  detected_at       DateTime?                 @default(now()) @db.Timestamp(6)
  created_at        DateTime?                 @default(now()) @db.Timestamp(6)
  updated_at        DateTime?                 @default(now()) @updatedAt @db.Timestamp(6)
  jobs              jobs                      @relation(fields: [job_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([job_id, fingerprint], map: "uk_findings_job_fingerprint")
  @@index([job_id], map: "idx_findings_job_id")
  @@index([severity], map: "idx_findings_severity")
  @@index([finding_type], map: "idx_findings_type")
  @@index([analyzer], map: "idx_findings_analyzer")
  @@index([detected_at], map: "idx_findings_detected_at")
  @@index([status], map: "idx_findings_status")
  @@index([fingerprint], map: "idx_findings_fingerprint")
}

model insights {
  id                 String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  job_id             String            @db.Uuid
  insight_type       insight_type
  title              String?           @db.VarChar(255)
  description        String?
  severity           insight_severity?
  priority_score     Float?
  confidence_score   Float?
  data               Json
  generated_by       insight_generator @default(LLM)
  model_name         String?           @db.VarChar(100)
  generation_version String?           @db.VarChar(50)
  finding_references Json?
  log_references     Json?
  is_visible         Boolean           @default(true)
  display_order      Int?
  metadata           Json?
  created_at         DateTime?         @default(now()) @db.Timestamp(6)
  updated_at         DateTime?         @default(now()) @updatedAt @db.Timestamp(6)
  jobs               jobs              @relation(fields: [job_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([job_id], map: "idx_insights_job_id")
  @@index([insight_type], map: "idx_insights_insight_type")
  @@index([severity], map: "idx_insights_severity")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model jobs {
  id                   String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id              String              @db.Uuid
  file_path            String
  file_name            String
  file_size            BigInt
  status               job_status_enum     @default(UPLOADED)
  last_completed_stage job_stage_enum?
  outcome              job_outcome_enum?
  progress             Int?                @default(0)
  retry_count          Int?                @default(0)
  error_message        String?
  processing_metadata  Json?
  created_at           DateTime?           @default(now()) @db.Timestamp(6)
  updated_at           DateTime?           @default(now()) @db.Timestamp(6)
  deleted_at           DateTime?           @db.Timestamp(6)
  job_name             String?             @db.VarChar(255)
  analyzer_findings    analyzer_findings[]
  insights             insights[]
  users                users               @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  normalized_logs      normalized_logs[]

  @@index([created_at], map: "idx_jobs_created_at")
  @@index([status], map: "idx_jobs_status")
  @@index([user_id], map: "idx_jobs_user_id")
}

model normalized_logs {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  job_id     String    @db.Uuid
  timestamp  DateTime  @db.Timestamp(6)
  source     String?   @db.VarChar(100)
  event_type String?   @db.VarChar(100)
  ip_address String?   @db.VarChar(50)
  severity   String?   @db.VarChar(50)
  metadata   Json?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  jobs       jobs      @relation(fields: [job_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([ip_address], map: "idx_logs_ip")
  @@index([job_id], map: "idx_logs_job_id")
  @@index([timestamp], map: "idx_logs_timestamp")
}

model users {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email         String    @unique @db.VarChar(255)
  password_hash String
  first_name    String?   @db.VarChar(100)
  last_name     String?   @db.VarChar(100)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  jobs          jobs[]

  @@index([email], map: "idx_users_email")
}

enum job_outcome_enum {
  SUCCESS
  WARNING
}

enum job_stage_enum {
  UPLOADED
  PREPROCESSED
  TYPE_DETECTED
  PARSED
  NORMALIZED
  ANALYZED
  INSIGHTS_GENERATED
  COMPLETED
}

enum job_status_enum {
  UPLOADED
  PROCESSING
  COMPLETED
  FAILED
}

enum analyzer_finding_severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum analyzer_finding_status {
  ACTIVE
  RESOLVED
  DISMISSED
  DUPLICATE
}

enum insight_type {
  OVERVIEW
  KPI
  ALERT
  THREAT_SUMMARY
  SEVERITY_DISTRIBUTION
  ACTIVITY_TIMELINE
  THREAT_TIMELINE
  TOP_ATTACKERS
  RECOMMENDATION
  ATTACK_PATTERN
  PORT_SCAN_PATTERN
  FAILED_LOGIN_ANALYSIS
  TRAFFIC_SPIKE
  EVENT_TYPE_DISTRIBUTION
  GEO_ANALYSIS
  SUSPICIOUS_IP_CLUSTER
  ANOMALY_SUMMARY
  ATTACK_CAMPAIGN
}

enum insight_severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum insight_generator {
  LLM
  DETERMINISTIC
  HYBRID
}
