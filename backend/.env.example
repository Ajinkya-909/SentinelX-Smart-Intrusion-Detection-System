# ===== SERVER CONFIGURATION =====
PORT=3000
NODE_ENV=development

# ===== DATABASE =====
# Priority 1: Docker PostgreSQL (used if running on localhost:5432)
DOCKER_DATABASE_URL=postgresql://postgres:supersecretpassword@localhost:5432/sentinelx_ids

# Priority 2: Neon Online PostgreSQL (used if Docker is not running)
NEON_DATABASE_URL=postgresql://neondb_owner:npg_7Scbo5HdrBtk@ep-young-thunder-ao8sjbkp.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Priority 3: Fallback/Default (used if both above are unavailable)
DEFAULT_DATABASE_URL=postgresql://postgres:supersecretpassword@localhost:5432/sentinelx_ids

# ===== REDIS =====
# Priority 1: Docker Redis (used if running on localhost:6379)
DOCKER_REDIS_URL=redis://localhost:6379

# Priority 2: Upstash Redis (used if Docker is not running)
UPSTASH_REDIS_URL=rediss://default:YOUR_UPSTASH_TOKEN@your-instance.upstash.io:6379

# Priority 3: Fallback/Default Redis
DEFAULT_REDIS_URL=redis://localhost:6379

# ===== JWT =====
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=7d

# ===== ML SERVICE =====
ML_SERVICE_URL=http://localhost:8000

# ===== FILE UPLOAD =====
MAX_FILE_SIZE=52428800
ALLOWED_EXTENSIONS=.csv,.json,.txt,.log
STORAGE_PATH=./storage

# ===== LOGGING =====
LOG_LEVEL=info

# ===== CORS =====
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ===== FEATURES =====
ENABLE_ML_ANALYSIS=true
ENABLE_RULE_ENGINE=true

JWT_SECRET=Trial
