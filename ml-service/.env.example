# ===== SERVER CONFIGURATION =====
HOST=0.0.0.0
PORT=8000
PYTHONUNBUFFERED=1

# ===== LOGGING =====
LOG_LEVEL=INFO

# ===== ISOLATION FOREST =====
# Controls the proportion of outliers in the data (contamination parameter)
IF_CONTAMINATION=0.05
# Number of trees in the forest
IF_N_ESTIMATORS=100

# ===== DBSCAN =====
# Maximum distance between samples in a cluster
DBSCAN_EPS=0.3
# Minimum number of samples to form a dense region
DBSCAN_MIN_SAMPLES=5

# ===== ANALYSIS TIMEOUTS =====
ANALYSIS_TIMEOUT_SECONDS=30

